FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      transportProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

transportModel  interTrackNewtonian;

nu [0 2 -1 0 0 0 0] 1e-6;
rho [1 -3 0 0 0 0 0] 1000; 

secondaryPhaseNu [0 2 -1 0 0 0 0] 1.2e-5;
secondaryPhaseRho [1 -3 0 0 0 0 0] 1; 


sigma [1 0 -2 0 0 0 0] 0.073;


