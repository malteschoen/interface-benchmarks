FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      dynamicMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dynamicFvMesh   interfaceTrackingFvMesh;

motionSolver    refVelocityLaplacian;

// diffusivity     uniform;
diffusivity quadratic repairedInverseDistance 2(freeSurface freeSurfaceShadow);

interpolation leastSquares;

nNonOrthogonalCorrectors 2;


// Free surface data

fsPatchName freeSurface;
fsShadowPatchName freeSurfaceShadow;

fixedFreeSurfacePatches 0();

pointNormalsCorrectionPatches 0();

normalMotionDir true;

motionDir (0 1 0);

pureFreeSurface true;
facSnGradUn false;
smoothing true;
totalFsDispl false;


fsMappingMethod directMap;
directMapCoeffs
{
}

