FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

libs
(
    "libtwoPhaseInterfaceTrackingDev.so"
);

application     itmPimpleFoam; // ZT: Required for bubble ITM cases

startFrom       startTime;

startTime       0;

stopAt          endTime;

endTime         0.5; //0.05;

deltaT          5e-6; // 0.00005

writeControl    timeStep;

writeInterval   50;

purgeWrite      0;

writeFormat     ascii;

writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable true;

functions
{
    bubbleMRF
    {
        type bubbleMRF;
        lambdaFf 1.0;
        lambdaF0 1.0;
        farFieldPatchName space;
    }
}

OptimisationSwitches
{
    faQuadricsFit 2;
}

