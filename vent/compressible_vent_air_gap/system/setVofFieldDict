FoamFile
{
    version         2;
    format          ascii;
    class           dictionary;
    location        "system";
    object          setVofFieldDict;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

field               "alpha.melt";
initial             0.0;
snapTol             1e-12;

triangulationScheme "centroid";
extraBooleanCheck   false;

exportPlicSurface   false;
exportIsoSurface    false;
writeShapes         false;

shapes
{
    box1
    {
        type        box;
        min         (-100 -100 -100);
        max         ( 100  100   0);
        mode        add;
    }

