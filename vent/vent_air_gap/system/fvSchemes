FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSchemes;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

ddtSchemes
{
    default         Euler;
}

gradSchemes
{
     default cellLimited Gauss linear 1;
}

divSchemes
{
    div(rhoPhi,U)   Gauss upwind;
    div(phi,k)      Gauss upwind;
    div(phi,omega)  Gauss upwind;
    div(((rho*nuEff)*dev2(T(grad(U))))) Gauss linear;
}

laplacianSchemes
{
    default         Gauss linear corrected;
}

interpolationSchemes
{
    //default         linear;
    default linear corrected;
}

snGradSchemes
{
    //default         corrected;
	default limited 0.5;
}

wallDist
{
    method          meshWave;
}


